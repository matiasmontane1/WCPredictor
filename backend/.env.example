# Environment: development (uses SQLite locally) | production (uses Supabase Postgres)
ENV=development

# Database
# Development (auto-set when ENV=development, no need to change):
DATABASE_URL=sqlite+aiosqlite:///./dev.db

# Production (Supabase connection string — replace with your project values):
# DATABASE_URL=postgresql+asyncpg://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# External API Keys
# Register at: https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=your_football_data_api_key_here

# Register at: https://the-odds-api.com (free tier: 500 req/month)
ODDS_API_KEY=your_odds_api_key_here

# Supabase (only needed for production)
# Get from: https://supabase.com → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here
